# Copy to .env and adjust before running `docker compose up`.

# --- PostgreSQL ---
DB_NAME=message_mesh_db
DB_USERNAME=message_mesh
DB_PASSWORD=change-me

# --- Backend / JWT ---
# Use a long, random value (>= 32 bytes) in production.
APP_JWT_SECRET=change-me-in-prod-please-use-a-long-random-secret-key-32b+
APP_JWT_EXPIRATION_MS=86400000
APP_ADMIN_USERNAME=alice

# Origin the browser uses to reach the frontend (used for CORS).
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081
